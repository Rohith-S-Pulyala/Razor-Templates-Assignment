@model CIS174_TestCoreApp_Pulyala.Models.Assignment61ViewModel

@{
    ViewData["Title"] = "Assignment 6.1";
}

<h2>Assignment 6.1</h2>
<p>Current Access Level: <strong>@Model.AccessLevel</strong></p>

@*Conditionals for Access Level, if Less than 2, access denied*@
@if (Model.AccessLevel < 2)
{
    <div class="alert alert-info">
        Insufficient Access Level
    </div>
}
else
{
    @*Access Granted, recognized as Admin if greater than 8*@
    @if (Model.AccessLevel >= 8)
    {
        <h3 class="text-primary">Hello Admin</h3>
    }
    <table class="table">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                @if (Model.AccessLevel >= 8)
                {
                    <th>Grade</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model.Students)
            {
                <tr>
                    @*Calls partial view and passes the student + access level*@
                    <partial name="_StudentRow" model="(student, Model.AccessLevel)" />
                </tr>
            }
        </tbody>
    </table>
}

    